          "padding": 0,
          "borderRadius": 16,
          "margin": {
            "left": 12,
            "right": 6,
            "top": 4,
            "bottom":1
          },
          "height": 64
        }
      },
      {
        "id": "leftIcon",
        "component": "Text",
