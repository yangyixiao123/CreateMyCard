{
  "version": "v3",
  "contract": "Self-contained normalized HarmonyOS A2UI Form layout templates for expression-first generation. Select at most one template, then keep size, root shell, region budgets, slot names, and full-expression binding style stable. Re-decide visible content, DataModel values, icons, colors, and only proven-valid onClick events. Historical observations have been folded into each manifest/sourceObservation; generation must not depend on reading any file outside this skill package.",
  "sourceAuditSummary": [
    "Ten rendered samples were reviewed and collapsed into nine distinct layout patterns; battery and sleep share the same side-meter/action structure.",
    "The historical samples used a different 2x2 canvas size, while this skill validates formal 2x2 templates at 146x146; all formal templates are normalized to 146x146.",
    "Old DSL patterns using multiple updateComponents messages, data URI images, undeclared SVG, emoji glyphs, or legacy action keys were not copied; only layout relationships and information density were retained.",
    "Three earlier generic templates were removed from the formal route list because they overlap these more specific patterns: compact meter/fact, generic top-hero pill, and generic paper panel."
  ],
  "templates": [
    {
      "id": "2x2-meter-side-action",
      "size": "2x2",
      "pattern": "meter-side-action",
      "manifest": "2x2-meter-side-action/manifest.json",
      "template": "2x2-meter-side-action/template.genui.jsonl",
      "cardspec": "2x2-meter-side-action/cardspec.json",
      "useWhen": ["battery", "low-battery", "power-saving", "sleep", "sleep-monitoring", "bedtime-reminder", "progress", "meter", "completion", "habit", "device-status"],
      "avoidWhen": ["no-progress-semantics", "two-primary-values", "center-label-longer-than-four-chars", "long-fact-list", "two-actions"],
      "slots": ["object", "asset.primaryIcon", "progress.value", "progress.total", "primary.value", "primary.caption", "support.1", "support.2", "asset.actionIcon", "action.label"]
    },
    {
      "id": "2x2-multi-meter-action",
      "size": "2x2",
      "pattern": "multi-meter-action",
      "manifest": "2x2-multi-meter-action/manifest.json",
      "template": "2x2-multi-meter-action/template.genui.jsonl",
      "cardspec": "2x2-multi-meter-action/cardspec.json",
      "useWhen": ["phone-status", "device-health", "cleanup", "multi-device", "memory", "storage"],
      "avoidWhen": ["single-metric-only", "icons-unavailable", "long-labels", "more-than-three-secondary-statuses"],
      "slots": ["object", "primary.value", "primary.total", "status.1.value", "status.2.value", "status.3.value", "asset.statusIcons", "action.label"]
    },
    {
      "id": "2x2-bar-dual-metric-action",
