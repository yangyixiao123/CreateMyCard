      "avoidWhen": ["no-threshold-semantics", "more-than-two-metrics", "exact-progress-width-unknown", "primary-value-needs-large-type"],
      "slots": ["object", "asset.primaryIcon", "progress.value", "progress.total", "progress.color", "metric.1.label", "metric.1.value", "metric.2.label", "metric.2.value", "action.label"]
    },
    {
      "id": "2x2-countdown-panel",
