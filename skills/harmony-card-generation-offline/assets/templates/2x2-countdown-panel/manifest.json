{
  "id": "2x2-countdown-panel",
  "size": "2x2",
  "pattern": "countdown-panel",
  "template": "template.genui.jsonl",
  "cardspec": "cardspec.json",
  "sourceObservation": "Derived from the marathon-countdown rendered sample: small event header, dominant two-digit countdown, and one bottom support panel.",
  "layoutSummary": "Small header, dominant two-digit countdown or large number, bottom support panel with a compact plan/fact.",
  "lockedStructure": {
    "surface": {
      "width": 146,
      "height": 146
    },
    "root": {
      "width": 146,
      "height": 146,
      "padding": 12,
      "borderRadius": 18,
      "clip": true
    },
    "sections": [
      {
        "id": "header",
        "width": 122,
        "height": 18
      },
      {
        "id": "countdownRow",
        "width": 122,
        "height": 44
      },
      {
        "id": "supportPanel",
        "width": 122,
        "height": 42
      }
    ]
  },
  "slots": {
    "object": {
      "path": "/card/title",
      "component": "eventTitle",
      "maxCharsCn": 8
    },
    "asset.primaryIcon": {
      "path": "/asset/primaryIcon",
      "component": "calendarIcon",
      "source": "reference/design/asset-library.md"
    },
    "primary.tens": {
      "path": "/countdown/tens",
      "component": "digitTens",
      "maxChars": 1
    },
    "primary.ones": {
      "path": "/countdown/ones",
      "component": "digitOnes",
      "maxChars": 1
    },
    "primary.unit": {
      "path": "/countdown/unit",
      "component": "unitText",
      "maxCharsCn": 1
    },
    "support.label": {
      "path": "/support/label",
      "component": "supportLabel",
      "maxCharsCn": 6
    },
    "support.value": {
      "path": "/support/value",
      "component": "supportValue",
      "maxCharsCn": 8
    }
  },
  "useWhen": [
    "countdown",
    "race",
    "deadline",
    "price-day-count",
    "step-goal",
    "limited-time"
  ],
  "avoidWhen": [
    "primary-value-longer-than-two-digits",
    "needs-action-and-two-facts",
    "date-range-is-primary"
  ],
  "allowedEdits": [
    "merge the digit boxes into one 40fp value if the value is one or two characters",
    "replace support icon through DataModel",
    "turn supportPanel into a single action only with valid event capability"
  ],
  "forbiddenEdits": [
    "add a second bottom panel",
    "show both countdown and exact date if they answer the same fact",
    "use emoji runner/calendar glyphs"
  ],
  "deleteRules": [
    "If support.value duplicates the countdown meaning, replace it with the next actionable plan or delete the support icon."
  ],
  "colorPolicy": {
    "source": "reference/design/color-token-system.md + color-token-values.md",
    "budget": "one temporal gradient plus neutral glass panels",
    "sceneFamily": "multi_color_01 / multi_color_aux_01 countdown purple",
    "roles": {
      "rootGradient": "multi_color_01 and multi_color_aux_01 temporal-band stops",
      "foreground": "font_on_primary/secondary on saturated gradient",
      "panels": "font_on_fourth/tertiary glass surfaces; no extra brand hue"
    },
    "rewriteRules": [
      "Keep countdown digits white/on-color.",
      "Do not use warning/alert for ordinary countdown support text."
    ]
  }
}
