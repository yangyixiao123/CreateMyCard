{
    "schemaVersion":  "template-v1",
    "id":  "countdown-panel",
    "size":  "2x2",
    "pattern":  "countdown-panel",
    "summary":  "Small header, dominant two-digit countdown or large number, bottom support panel with a compact plan/fact.",
    "template":  "template.genui.jsonl",
    "cardspec":  "cardspec.json",
    "sourceProvenance":  [
                             "Derived from the marathon-countdown rendered sample: small event header, dominant two-digit countdown, and one bottom support panel."
                         ],
    "useWhen":  [
                    "countdown",
                    "race",
                    "deadline",
                    "price-day-count",
                    "step-goal",
                    "limited-time"
                ],
    "avoidWhen":  [
                      "primary-value-longer-than-two-digits",
                      "needs-action-and-two-facts",
                      "date-range-is-primary"
                  ],
    "layout":  {
                   "canvas":  {
                                  "width":  160,
                                  "height":  160
                              },
                   "root":  {
                                "width":  160,
                                "height":  160,
                                "padding":  12,
                                "borderRadius":  18,
                                "clip":  true
                            },
                   "regions":  [
                                   {
                                       "id":  "header",
                                       "role":  "identity",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  18,
                                       "required":  true,
                                       "maxChildren":  2,
                                       "allowedComponents":  [
                                                                 "Image",
                                                                 "Row",
                                                                 "Text"
                                                             ]
                                   },
                                   {
                                       "id":  "countdownRow",
                                       "role":  "primary",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  44,
                                       "required":  true,
                                       "maxChildren":  3,
                                       "allowedComponents":  [
                                                                 "Column",
                                                                 "Row",
                                                                 "Text"
                                                             ]
                                   },
                                   {
                                       "id":  "supportPanel",
                                       "role":  "support",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  42,
                                       "required":  false,
                                       "maxChildren":  2,
                                       "allowedComponents":  [
                                                                 "Column",
                                                                 "Image",
                                                                 "Row",
                                                                 "Text",
                                                                 "Divider"
                                                             ]
                                   }
                               ],
                   "safeArea":  {
                                    "x":  12,
                                    "y":  12,
                                    "width":  136,
                                    "height":  136
                                }
               },
    "componentVariants":  {
                              "header":  [
                                             {
                                                 "id":  "default",
                                                 "rootComponent":  "Row",
                                                 "allowedComponents":  [
                                                                           "Image",
                                                                           "Row",
                                                                           "Text"
                                                                       ]
                                             },
                                             {
                                                 "id":  "text-only",
                                                 "rootComponent":  "Text",
                                                 "allowedComponents":  [
                                                                           "Text"
                                                                       ]
                                             }
                                         ],
                              "countdownRow":  [
                                                   {
                                                       "id":  "default",
                                                       "rootComponent":  "Row",
                                                       "allowedComponents":  [
                                                                                 "Column",
                                                                                 "Row",
                                                                                 "Text"
                                                                             ]
                                                   }
                                               ],
                              "supportPanel":  [
                                                   {
                                                       "id":  "default",
                                                       "rootComponent":  "Row",
                                                       "allowedComponents":  [
                                                                                 "Column",
                                                                                 "Image",
                                                                                 "Row",
                                                                                 "Text"
                                                                             ]
                                                   },
                                                   {
                                                       "id":  "compact-text",
                                                       "rootComponent":  "Column",
                                                       "allowedComponents":  [
                                                                                 "Column",
                                                                                 "Row",
                                                                                 "Text",
                                                                                 "Divider"
                                                                             ]
                                                   }
                                               ]
                          },
    "slots":  {
                  "object":  {
                                 "path":  "/card/title",
                                 "role":  "object",
                                 "region":  "header",
                                 "required":  true,
                                 "bindingKinds":  [
                                                      "static",
                                                      "expression",
                                                      "path"
                                                  ],
                                 "component":  "eventTitle",
                                 "maxCharsCn":  8
                             },
                  "asset.primaryIcon":  {
                                            "path":  "/asset/primaryIcon",
                                            "role":  "asset",
                                            "region":  "header",
                                            "required":  false,
                                            "bindingKinds":  [
                                                                 "static",
                                                                 "expression",
                                                                 "path"
                                                             ],
                                            "component":  "calendarIcon",
                                            "source":  "references/design/asset-library.md"
                                        },
                  "primary.tens":  {
                                       "path":  "/countdown/tens",
                                       "role":  "primary",
                                       "region":  "countdownRow",
                                       "required":  true,
                                       "bindingKinds":  [
                                                            "static",
                                                            "expression",
                                                            "path"
                                                        ],
                                       "component":  "digitTens",
                                       "maxChars":  1
                                   },
                  "primary.ones":  {
                                       "path":  "/countdown/ones",
                                       "role":  "primary",
                                       "region":  "countdownRow",
                                       "required":  true,
                                       "bindingKinds":  [
                                                            "static",
                                                            "expression",
                                                            "path"
                                                        ],
                                       "component":  "digitOnes",
                                       "maxChars":  1
                                   },
                  "primary.unit":  {
                                       "path":  "/countdown/unit",
                                       "role":  "primary",
                                       "region":  "countdownRow",
                                       "required":  true,
                                       "bindingKinds":  [
                                                            "static",
                                                            "expression",
                                                            "path"
                                                        ],
                                       "component":  "unitText",
                                       "maxCharsCn":  1
                                   },
                  "support.label":  {
                                        "path":  "/support/label",
                                        "role":  "support",
                                        "region":  "supportPanel",
                                        "required":  false,
                                        "bindingKinds":  [
                                                             "static",
                                                             "expression",
                                                             "path"
                                                         ],
                                        "component":  "supportLabel",
                                        "maxCharsCn":  6
                                    },
                  "support.value":  {
                                        "path":  "/support/value",
                                        "role":  "support",
                                        "region":  "supportPanel",
                                        "required":  false,
                                        "bindingKinds":  [
                                                             "static",
                                                             "expression",
                                                             "path"
                                                         ],
                                        "component":  "supportValue",
                                        "maxCharsCn":  8
                                    }
              },
    "defaultStyleProfile":  "ambient-scene",
    "allowedStyleProfiles":  [
                                 "ambient-scene",
                                 "dark-focus"
                             ],
    "colorRoles":  {
                       "rootGradient":  "multi_color_01 and multi_color_aux_01 temporal-band stops",
                       "foreground":  "font_on_primary/secondary on saturated gradient",
                       "panels":  "font_on_fourth/tertiary glass surfaces; no extra brand hue"
                   },
    "allowedEdits":  [
                         "merge the digit boxes into one 40fp value if the value is one or two characters",
                         "replace support icon through DataModel",
                         "turn supportPanel into a single action only with valid event capability"
                     ],
    "forbiddenEdits":  [
                           "add a second bottom panel",
                           "show both countdown and exact date if they answer the same fact",
                           "use emoji runner/calendar glyphs"
                       ],
    "deleteRules":  [
                        "If support.value duplicates the countdown meaning, replace it with the next actionable plan or delete the support icon."
                    ]
}
