{
    "schemaVersion":  "template-v1",
    "id":  "stacked-schedule-action",
    "size":  "2x2",
    "pattern":  "stacked-schedule-action",
    "summary":  "Vertical schedule stack optimized for one upcoming event and one action/support pill.",
    "template":  "template.genui.jsonl",
    "cardspec":  "cardspec.json",
    "sourceProvenance":  [
                             "Derived from the focus rendered sample: a compact schedule label, centered title and large time range, one alert line, and one bottom focus/action pill."
                         ],
    "useWhen":  [
                    "next-schedule",
                    "focus-mode",
                    "meeting-reminder",
                    "single-event",
                    "class-reminder"
                ],
    "avoidWhen":  [
                      "needs-room-and-participants",
                      "multiple-events",
                      "very-long-event-title",
                      "time-range-longer-than-11-chars"
                  ],
    "layout":  {
                   "canvas":  {
                                  "width":  160,
                                  "height":  160
                              },
                   "root":  {
                                "width":  160,
                                "height":  160,
                                "padding":  12,
                                "borderRadius":  18,
                                "clip":  true
                            },
                   "regions":  [
                                   {
                                       "id":  "scheduleHeader",
                                       "role":  "identity",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  18,
                                       "required":  true,
                                       "maxChildren":  2,
                                       "allowedComponents":  [
                                                                 "Image",
                                                                 "Row",
                                                                 "Text"
                                                             ]
                                   },
                                   {
                                       "id":  "eventTitle",
                                       "role":  "primary",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  18,
                                       "required":  true,
                                       "maxChildren":  1,
                                       "allowedComponents":  [
                                                                 "Text"
                                                             ]
                                   },
                                   {
                                       "id":  "timeText",
                                       "role":  "primary",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  24,
                                       "required":  true,
                                       "maxChildren":  1,
                                       "allowedComponents":  [
                                                                 "Text"
                                                             ]
                                   },
                                   {
                                       "id":  "alertRow",
                                       "role":  "support",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  18,
                                       "required":  false,
                                       "maxChildren":  2,
                                       "allowedComponents":  [
                                                                 "Image",
                                                                 "Row",
                                                                 "Text",
                                                                 "Column",
                                                                 "Divider"
                                                             ]
                                   },
                                   {
                                       "id":  "actionPill",
                                       "role":  "action",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  26,
                                       "required":  false,
                                       "maxChildren":  2,
                                       "allowedComponents":  [
                                                                 "Button",
                                                                 "Image",
                                                                 "Row",
                                                                 "Text"
                                                             ]
                                   }
                               ],
                   "safeArea":  {
                                    "x":  12,
                                    "y":  12,
                                    "width":  136,
                                    "height":  136
                                }
               },
    "componentVariants":  {
                              "scheduleHeader":  [
                                                     {
                                                         "id":  "default",
                                                         "rootComponent":  "Row",
                                                         "allowedComponents":  [
                                                                                   "Image",
                                                                                   "Row",
                                                                                   "Text"
                                                                               ]
                                                     },
                                                     {
                                                         "id":  "text-only",
                                                         "rootComponent":  "Text",
                                                         "allowedComponents":  [
                                                                                   "Text"
                                                                               ]
                                                     }
                                                 ],
                              "eventTitle":  [
                                                 {
                                                     "id":  "default",
                                                     "rootComponent":  "Text",
                                                     "allowedComponents":  [
                                                                               "Text"
                                                                           ]
                                                 }
                                             ],
                              "timeText":  [
                                               {
                                                   "id":  "default",
                                                   "rootComponent":  "Text",
                                                   "allowedComponents":  [
                                                                             "Text"
                                                                         ]
                                               }
                                           ],
                              "alertRow":  [
                                               {
                                                   "id":  "default",
                                                   "rootComponent":  "Row",
                                                   "allowedComponents":  [
                                                                             "Image",
                                                                             "Row",
                                                                             "Text"
                                                                         ]
                                               },
                                               {
                                                   "id":  "compact-text",
                                                   "rootComponent":  "Column",
                                                   "allowedComponents":  [
                                                                             "Column",
                                                                             "Row",
                                                                             "Text",
                                                                             "Divider"
                                                                         ]
                                               }
                                           ],
                              "actionPill":  [
                                                 {
                                                     "id":  "default",
                                                     "rootComponent":  "Row",
                                                     "allowedComponents":  [
                                                                               "Button",
                                                                               "Image",
                                                                               "Row",
                                                                               "Text"
                                                                           ]
                                                 },
                                                 {
                                                     "id":  "button",
                                                     "rootComponent":  "Button",
                                                     "allowedComponents":  [
                                                                               "Button"
                                                                           ]
                                                 },
                                                 {
                                                     "id":  "static-support",
                                                     "rootComponent":  "Row",
                                                     "allowedComponents":  [
                                                                               "Row",
                                                                               "Image",
                                                                               "Text"
                                                                           ]
                                                 }
                                             ]
                          },
    "slots":  {
                  "object":  {
                                 "path":  "/card/title",
                                 "role":  "object",
                                 "region":  "scheduleHeader",
                                 "required":  true,
                                 "bindingKinds":  [
                                                      "static",
                                                      "expression",
                                                      "path"
                                                  ],
                                 "component":  "scheduleLabel",
                                 "maxCharsCn":  6
                             },
                  "primary.title":  {
                                        "path":  "/event/title",
                                        "role":  "primary",
                                        "region":  "eventTitle",
                                        "required":  true,
                                        "bindingKinds":  [
                                                             "static",
                                                             "expression",
                                                             "path"
                                                         ],
                                        "component":  "eventTitle",
                                        "maxCharsCn":  8
                                    },
                  "primary.time":  {
                                       "path":  "/event/time",
                                       "role":  "primary",
                                       "region":  "timeText",
                                       "required":  true,
                                       "bindingKinds":  [
                                                            "static",
                                                            "expression",
                                                            "path"
                                                        ],
                                       "component":  "timeText",
                                       "maxChars":  11
                                   },
                  "support.1":  {
                                    "path":  "/event/alert",
                                    "role":  "support",
                                    "region":  "alertRow",
                                    "required":  false,
                                    "bindingKinds":  [
                                                         "static",
                                                         "expression",
                                                         "path"
                                                     ],
                                    "component":  "alertText",
                                    "maxCharsCn":  8
                                },
                  "action.label":  {
                                       "path":  "/action/label",
                                       "role":  "action",
                                       "region":  "actionPill",
                                       "required":  false,
                                       "bindingKinds":  [
                                                            "static",
                                                            "expression",
                                                            "path"
                                                        ],
                                       "component":  "actionText",
                                       "maxCharsCn":  5
                                   }
              },
    "defaultStyleProfile":  "ambient-scene",
    "allowedStyleProfiles":  [
                                 "ambient-scene",
                                 "neutral-light",
                                 "dark-focus"
                             ],
    "colorRoles":  {
                       "rootGradient":  "multi_color_09 and multi_color_aux_09 temporal-band stops",
                       "foreground":  "font_on_primary/secondary on saturated gradient",
                       "alertLine":  "on-color support text unless the event is truly warning/alert",
                       "action":  "font_on_fourth/tertiary glass material by default"
                   },
    "allowedEdits":  [
                         "delete alertRow and increase eventTitle height when alert is unavailable",
                         "replace icons through DataModel",
                         "add onClick to actionPill only with valid event capability"
                     ],
    "forbiddenEdits":  [
                           "add a second event",
                           "split one event into repeated labels",
                           "show time twice under different labels"
                       ],
    "deleteRules":  [
                        "If event.title exceeds the protected width, shorten title; if it still cannot fit, abandon this 2x2 template and re-evaluate size/layout through the normal rules."
                    ]
}
