                                            "two-actions"
                                        ],
                          "roles":  [
                                        "action",
                                        "identity",
                                        "primary"
                                    ],
                          "slots":  [
                                        "object",
                                        "asset.primaryIcon",
                                        "progress.value",
                                        "progress.total",
