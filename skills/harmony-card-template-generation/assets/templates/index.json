{
    "schemaVersion":  "template-index-v1",
    "contract":  "Select exactly one template after hard filtering by size, roles, action count, capability count, asset availability and protected-text budget. Keep region geometry fixed and only use declared component variants.",
    "safeFallbacks":  {
                          "2x2":  "spotlight-context-action",
                          "2x4":  "hero-context-action"
                      },
    "sourceAuditSummary":  [
                               "Ten historical 2x2 samples were consolidated into nine distinct normalized patterns.",
                               "Two historical 2x4 layouts were normalized and two wide patterns were derived from proven 2x2 structures.",
                               "Legacy theme, emoji, base64, network media, undeclared events and incompatible catalog fields were not copied."
                           ],
    "templates":  [
                      {
