{
    "schemaVersion":  "template-v1",
    "id":  "spotlight-context-action",
    "size":  "2x2",
    "pattern":  "spotlight-context-action",
    "summary":  "Hero icon/value row, contextual info panel with accent line, bottom action/support pill.",
    "template":  "template.genui.jsonl",
    "cardspec":  "cardspec.json",
    "sourceProvenance":  [
                             "Derived from the weather/taxi rendered sample: a strong top hero row, one middle context card, and one full-width bottom action."
                         ],
    "useWhen":  [
                    "weather",
                    "commute",
                    "taxi",
                    "spotlight-status",
                    "single-event-context",
                    "alert-with-action"
                ],
    "avoidWhen":  [
                      "long-context-title",
                      "two-primary-values",
                      "multiple-actions",
                      "no-clear-context-card"
                  ],
    "layout":  {
                   "canvas":  {
                                  "width":  160,
                                  "height":  160
                              },
                   "root":  {
                                "width":  160,
                                "height":  160,
                                "padding":  12,
                                "borderRadius":  18,
                                "clip":  true
                            },
                   "regions":  [
                                   {
                                       "id":  "heroRow",
                                       "role":  "primary",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  42,
                                       "required":  true,
                                       "maxChildren":  2,
                                       "allowedComponents":  [
                                                                 "Column",
                                                                 "Image",
                                                                 "Row",
                                                                 "Stack",
                                                                 "Text"
                                                             ]
                                   },
                                   {
                                       "id":  "contextCard",
                                       "role":  "support",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  36,
                                       "required":  false,
                                       "maxChildren":  2,
                                       "allowedComponents":  [
                                                                 "Column",
                                                                 "Divider",
                                                                 "Row",
                                                                 "Text"
                                                             ]
                                   },
                                   {
                                       "id":  "actionPill",
                                       "role":  "action",
                                       "parent":  "root",
                                       "width":  136,
                                       "height":  26,
                                       "required":  false,
                                       "maxChildren":  2,
                                       "allowedComponents":  [
                                                                 "Button",
                                                                 "Image",
                                                                 "Row",
                                                                 "Text"
                                                             ]
                                   }
                               ],
                   "safeArea":  {
                                    "x":  12,
                                    "y":  12,
                                    "width":  136,
                                    "height":  136
                                }
               },
    "componentVariants":  {
                              "heroRow":  [
                                              {
                                                  "id":  "default",
                                                  "rootComponent":  "Row",
                                                  "allowedComponents":  [
                                                                            "Column",
                                                                            "Image",
                                                                            "Row",
                                                                            "Stack",
                                                                            "Text"
                                                                        ]
                                              }
                                          ],
                              "contextCard":  [
                                                  {
                                                      "id":  "default",
                                                      "rootComponent":  "Row",
                                                      "allowedComponents":  [
                                                                                "Column",
                                                                                "Divider",
                                                                                "Row",
                                                                                "Text"
                                                                            ]
                                                  },
                                                  {
                                                      "id":  "compact-text",
                                                      "rootComponent":  "Column",
                                                      "allowedComponents":  [
                                                                                "Column",
                                                                                "Row",
                                                                                "Text",
                                                                                "Divider"
                                                                            ]
                                                  }
                                              ],
                              "actionPill":  [
                                                 {
                                                     "id":  "default",
                                                     "rootComponent":  "Row",
                                                     "allowedComponents":  [
                                                                               "Button",
                                                                               "Image",
                                                                               "Row",
                                                                               "Text"
                                                                           ]
                                                 },
                                                 {
                                                     "id":  "button",
                                                     "rootComponent":  "Button",
                                                     "allowedComponents":  [
                                                                               "Button"
                                                                           ]
                                                 },
                                                 {
                                                     "id":  "static-support",
                                                     "rootComponent":  "Row",
                                                     "allowedComponents":  [
                                                                               "Row",
                                                                               "Image",
                                                                               "Text"
                                                                           ]
                                                 }
                                             ]
                          },
    "slots":  {
                  "asset.primaryIcon":  {
                                            "path":  "/asset/primaryIcon",
                                            "role":  "asset",
                                            "region":  "heroRow",
                                            "required":  false,
                                            "bindingKinds":  [
                                                                 "static",
                                                                 "expression",
                                                                 "path"
                                                             ],
                                            "component":  "primaryIcon",
                                            "source":  "references/design/asset-library.md"
                                        },
                  "primary.value":  {
                                        "path":  "/primary/value",
                                        "role":  "primary",
                                        "region":  "heroRow",
                                        "required":  true,
                                        "bindingKinds":  [
                                                             "static",
                                                             "expression",
                                                             "path"
                                                         ],
                                        "component":  "primaryValue",
                                        "maxChars":  4
                                    },
                  "primary.caption":  {
                                          "path":  "/primary/caption",
                                          "role":  "primary",
                                          "region":  "heroRow",
                                          "required":  true,
                                          "bindingKinds":  [
                                                               "static",
                                                               "expression",
                                                               "path"
                                                           ],
                                          "component":  "primaryCaption",
                                          "maxChars":  10
                                      },
                  "support.title":  {
                                        "path":  "/support/title",
                                        "role":  "support",
                                        "region":  "contextCard",
                                        "required":  false,
                                        "bindingKinds":  [
                                                             "static",
                                                             "expression",
                                                             "path"
                                                         ],
                                        "component":  "contextTitle",
                                        "maxCharsCn":  8
                                    },
                  "support.meta":  {
                                       "path":  "/support/meta",
                                       "role":  "support",
                                       "region":  "contextCard",
                                       "required":  false,
                                       "bindingKinds":  [
                                                            "static",
                                                            "expression",
                                                            "path"
                                                        ],
                                       "component":  "contextMeta",
                                       "maxChars":  12
                                   },
                  "action.label":  {
                                       "path":  "/action/label",
                                       "role":  "action",
                                       "region":  "actionPill",
                                       "required":  false,
                                       "bindingKinds":  [
                                                            "static",
                                                            "expression",
                                                            "path"
                                                        ],
                                       "component":  "actionLabel",
                                       "maxCharsCn":  6
                                   }
              },
    "defaultStyleProfile":  "ambient-scene",
    "allowedStyleProfiles":  [
                                 "ambient-scene",
                                 "neutral-light",
                                 "dark-focus"
                             ],
    "colorRoles":  {
                       "rootGradient":  "multi_color_02 and multi_color_aux_02 ambient-band stops",
                       "foreground":  "font_on_primary/secondary on saturated gradient",
                       "context":  "font_on_fourth/tertiary glass material",
                       "action":  "brand only for clear open/navigate/detail action"
                   },
    "allowedEdits":  [
                         "delete visualMark and give primaryInfo width 116",
                         "add onClick to actionPill only with valid event capability",
                         "change accent line color within token palette"
                     ],
    "forbiddenEdits":  [
                           "add another context card",
                           "use weather emoji",
                           "repeat primary.value in contextMeta"
                       ],
    "deleteRules":  [
                        "If support.title and support.meta are not both useful, merge contextCard into one support line; if no clear context remains, abandon this template."
                    ]
}
