{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harmony.cardspec.schema",
  "type": "object",
  "required": ["title", "description", "suggestSize"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "suggestSize": {
      "type": "string",
      "enum": ["2x2", "2x4"]
    },
    "dataBindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["capabilityId", "arguments", "writeResultTo"],
        "properties": {
          "bindingId": {
            "type": "string"
          },
          "capabilityId": {
            "type": "string"
          },
          "capabilityVersion": {
            "type": "string"
          },
          "arguments": {
            "type": "object"
          },
          "writeResultTo": {
            "type": "string",
            "pattern": "^/data(/|$).+"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
